{
  "manifest_version": 3,
  "name": "Lume Web Companion",
  "version": "0.2.0",
  "description": "Detecta agentes de IA no navegador e recebe prompts locais do Lume.",
  "host_permissions": [
    "http://127.0.0.1:43120/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Lume Web Companion",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
