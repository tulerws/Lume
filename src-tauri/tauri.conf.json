{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lume",
  "version": "0.3.4",
  "identifier": "com.tulerws.lume",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:vscode && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Lume",
        "width": 78,
        "height": 44,
        "minWidth": 72,
        "minHeight": 44,
        "maxWidth": 392,
        "maxHeight": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/lume-vscode.vsix": "lume-vscode.vsix",
      "../extensions/chromium/": "chromium/"
    },
    "linux": {
      "deb": {
        "depends": [
          "libgtk-layer-shell0"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY4OTJDMEIxMkFFMDU0QzEKUldUQlZPQXFzY0NTYURxcVJrZ2pGMHVaM1JoZnYzZjljMjNqMEd4Qyt1YnY0WUhwcms5Yk83ODgK",
      "endpoints": [
        "https://github.com/tulerws/Lume/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
